{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NugetTranslation 配置",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema 引用。"
    }
  },
  "patternProperties": {
    "^[^\\$].*$": {
      "$ref": "#/$defs/ProfileConfig"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "ProfileConfig": {
      "type": "object",
      "properties": {
        "baseDir": {
          "type": "string",
          "description": "工作目录基础路径，相对于编译输出目录（bin/Debug/net10.0/）。空字符串表示不改变。如 \"..\\..\\..\\..\" 指向仓库根。"
        },
        "logLevel": {
          "type": "string",
          "enum": ["Verbose", "Debug", "Information", "Warning", "Error", "Fatal"],
          "default": "Information",
          "description": "Serilog 日志最低等级。"
        },
        "ai": {
          "$ref": "#/$defs/AIConfig",
          "description": "AI 模型连接配置。"
        }
      },
      "required": ["ai"]
    },
    "AIConfig": {
      "type": "object",
      "properties": {
        "url": { "$ref": "#/$defs/AIConfigSource", "description": "API 端点 URL。" },
        "model": { "$ref": "#/$defs/AIConfigSource", "description": "模型名称。" },
        "key": { "$ref": "#/$defs/AIConfigSource", "description": "API Key。" }
      },
      "required": ["url", "model", "key"]
    },
    "AIConfigSource": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "$type": { "const": "constant" },
            "value": { "type": "string", "description": "固定值，直接使用。" }
          },
          "required": ["$type", "value"]
        },
        {
          "type": "object",
          "properties": {
            "$type": { "const": "env" },
            "value": { "type": "string", "description": "环境变量名，从进程环境变量读取。" }
          },
          "required": ["$type", "value"]
        },
        {
          "type": "object",
          "properties": {
            "$type": { "const": "secrets" },
            "value": { "type": "string", "description": "UserSecrets 键名，需先执行 `dotnet user-secrets set \"键名\" \"值\"`。" }
          },
          "required": ["$type", "value"]
        }
      ]
    }
  }
}
