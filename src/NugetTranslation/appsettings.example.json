{
  // ===== 配置 Profile ====
  // 通过 --profile 选项选择使用哪个配置节。
  // 示例：NugetTranslation zh-Hans --profile local translate ...

  // ---------- 本地开发用 (--profile local) ----------
  "local": {
    // baseDir: 工作目录基础路径，相对于编译输出目录。空字符串表示不改变
    "baseDir": "..\\..\\..\\..",
    // logLevel: 可选值 Verbose | Debug | Information | Warning | Error | Fatal
    "logLevel": "Information",
    "ai": {
      // $type 可选值：
      //   "constant" — 直接使用 value 中的固定值
      //   "env"      — 从环境变量读取 value 中指定的变量名
      //   "secrets"  — 从 dotnet user-secrets 读取 value 中指定的键
      "url":   { "$type": "constant", "value": "https://api.deepseek.com" },
      "model": { "$type": "env",      "value": "MODEL" },
      "key":   { "$type": "env",      "value": "APIKEY" }
    }
  },

  // ---------- GitHub Actions 用 (--profile github) ----------
  "github": {
    "baseDir": "",
    "logLevel": "Information",
    "ai": {
      "url":   { "$type": "env", "value": "ENDPOINT" },
      "model": { "$type": "env", "value": "MODEL" },
      "key":   { "$type": "env", "value": "APIKEY" }
    }
  },

  // ---------- 发布用 (--profile release) ----------
  "release": {
    "baseDir": "",
    "logLevel": "Information",
    "ai": {
      "url":   { "$type": "env", "value": "ENDPOINT" },
      "model": { "$type": "env", "value": "MODEL" },
      "key":   { "$type": "env", "value": "APIKEY" }
    }
  }
}
